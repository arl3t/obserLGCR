# obserLGCR — variables de entorno (fork demo, sin autenticación).
# Copiar a .env y ajustar. Todos tienen defaults razonables en docker-compose.

# ── Postgres ───────────────────────────────────────────────────────────────
PG_USER=obserlgcr
PG_PASSWORD=obserlgcr
PG_DATABASE=obserlgcr
PG_PORT=5432

# ── Puertos publicados en el host ──────────────────────────────────────────
API_PORT=8787
DASHBOARD_PORT=8080

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Autenticación ──────────────────────────────────────────────────────────
# Dejar OIDC_ENABLED=false (default) = SIN autenticación: todas las requests
# pasan como usuario admin sintético. Para activar Keycloak más adelante, ver
# api/middleware/auth.middleware.mjs (fases 2 y 3).
OIDC_ENABLED=false
