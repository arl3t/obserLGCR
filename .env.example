# obserLGCR — variables de entorno (fork demo, sin autenticación).
# Copiar a .env y ajustar. Todos tienen defaults razonables en docker-compose.

# ── Postgres (TimescaleDB en docker-compose) ─────────────────────────────────
PG_USER=obserlgcr
PG_PASSWORD=obserlgcr
PG_DATABASE=obserlgcr
PG_PORT=5432

# ── Dashboard (solo si corre `npm run dev` fuera de Docker) ────────────────
# Dejar vacío: el proxy Vite (:5173) y nginx Docker (:8080) reenvían /api al API.
# Definir solo si el front se sirve sin proxy (p. ej. build estático en otro host):
# VITE_API_BASE_URL=http://192.168.1.10:8787

# ── Puertos publicados en el host ──────────────────────────────────────────
API_PORT=8787
DASHBOARD_PORT=8080
# ── IPAM / nmap (microservicio FastAPI) ─────────────────────────────────────
IPAM_PORT=8790
NMAP_TIMEOUT_SEC=600
NMAP_HOST_TIMEOUT_SEC=5

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Autenticación ──────────────────────────────────────────────────────────
OIDC_ENABLED=false
PLATFORM_AUTH_ENABLED=true
AGENT_JWT_SECRET=change-me-agent-jwt-secret

# ── NOC + observabilidad TimescaleDB ───────────────────────────────────────
NOC_AGENT_TOKEN=
NOC_WATCHER_INTERVAL_MS=30000
NOC_AUTO_INCIDENT=true
GOVERNANCE_INCIDENT_WORKER=true
GOVERNANCE_INCIDENT_INTERVAL_MS=15000
NOC_LAKE_ROOT=./data/lake/noc
NOC_DEFAULT_REGION=global
CRON_SECRET=

# ── SNMP / Telegraf (opcional) ───────────────────────────────────────────────
SNMP_COMMUNITY=public
SNMP_TARGET_1=192.168.1.1
# Descubrimiento: POST /api/noc/snmp/discover o UI Config → SNMP (requiere UDP/161 desde el contenedor API)
