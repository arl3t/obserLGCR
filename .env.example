# obserLGCR — variables de entorno (fork demo, sin autenticación).
# Copiar a .env y ajustar. Todos tienen defaults razonables en docker-compose.

# ── Postgres ───────────────────────────────────────────────────────────────
PG_USER=obserlgcr
PG_PASSWORD=obserlgcr
PG_DATABASE=obserlgcr
PG_PORT=5432

# ── Puertos publicados en el host ──────────────────────────────────────────
API_PORT=8787
DASHBOARD_PORT=8080

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Autenticación ──────────────────────────────────────────────────────────
OIDC_ENABLED=false
# Auth local dashboard (PostgreSQL). false = modo lab sin login.
PLATFORM_AUTH_ENABLED=true
# Dashboard: VITE_PLATFORM_AUTH=false desactiva login en UI (modo lab)
AGENT_JWT_SECRET=change-me-agent-jwt-secret

# ── NOC (monitoreo de infraestructura) ─────────────────────────────────────
# Token estático legacy (opcional). Los agentes pueden usar JWT vía POST /api/auth/token.
NOC_AGENT_TOKEN=
# Secreto para firmar JWT de agentes (recomendado en producción).
AGENT_JWT_SECRET=change-me-agent-jwt-secret
# Watcher interno de heartbeats (ms). 0 = desactivado.
NOC_WATCHER_INTERVAL_MS=30000
# Secreto para cron externo: GET /api/noc/cron/heartbeat-watcher
CRON_SECRET=
