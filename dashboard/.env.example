# Base URL del legacyhunt-api (sin barra final). Si está vacío:
#   - `npm run dev`: peticiones a /api → proxy Vite → :8787.
#   - `npm run build` + preview/serve en localhost o IP LAN: el código usa por defecto http(s)://<mismo-host>:8787
#     (evita que /api devuelva index.html). En dominio público sin 8787 expuesto, defina la URL real del API aquí y rebuild.
VITE_API_BASE_URL=

# Si legacyhunt-api usa INGEST_API_KEY, misma clave aquí para Credential exposure → S3
VITE_INGEST_API_KEY=

# Misma clave que TRINO_PROXY_API_KEY en legacyhunt-api (si está definida). El cliente Axios la envía
# en X-Api-Key en todas las peticiones al API, para que POST /api/trino/query (fallback SQL) autentique.
# No confundir con el JWT de login: el proxy prioriza X-Api-Key sobre Bearer.
VITE_TRINO_PROXY_API_KEY=

# Catálogo Trino del dashboard (lab: minio tras sync AWS → MinIO). Ver docs/INGESTA-OPNSENSE-WAZUH-TRINO.md §0
# "3" o "s3" en catálogo se corrigen a minio en el código del front.
VITE_TRINO_CATALOG=minio
VITE_TRINO_SCHEMA=hunting

# Iceberg threat-hunt (enriched_ioc, vt_results). Vacío + catálogo minio → se usa minio_iceberg.hunting.
# VITE_TRINO_HUNTING_CATALOG=minio_iceberg

# Tabla/vista Wazuh (Trino). Si se omite, el dashboard usa ${VITE_TRINO_CATALOG}.${VITE_TRINO_SCHEMA}.wazuh_alerts
# (p. ej. minio.hunting.wazuh_alerts). Vista unión syslog+alerts: ./scripts/bootstrap-trino-wazuh-view.sh → .wazuh
# VITE_TRINO_WAZUH_TABLE=minio.hunting.wazuh_alerts

# Perímetro interno del Overview (OPNsense/syslog/Wazuh/remitentes) con datos de laboratorio — mismo patrón que commit #demo (1a8e3c0b) + mock.
# No afecta vigilancia digital. Tras editar: npm run dev.
# VITE_INTERNAL_PERIMETER_MOCK=1

# Sentry (opcional en dev)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
